# Server
PORT=8081
UIGP_API_KEY=dev-key
MAX_BODY_BYTES=8388608

# CI 
LLM_PROVIDER=fake

# Chat limits
MAX_HISTORY_ITEMS=20
MAX_HISTORY_CHARS=12000
LLM_CONCURRENCY=1

DOMAIN_STRICT=true
DOMAIN_KEYWORDS=microservice,service,services,api,gateway,ingress,kubernetes,k8s,docker,container,grpc,rest,http,kafka,queue,event,postgres,mysql,db,database,cache,redis,latency,p95,rps,throughput,scaling,autoscaling,slo,sla,observability,logging,tracing,prometheus,grafana,otel

# LLM Provider (pluggable)
LLM_PROVIDER=ollama

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:instruct
OLLAMA_TIMEOUT=180s

# Ollama generation options (used later if you wire config into opts)
OLLAMA_NUM_CTX=1024
OLLAMA_NUM_PREDICT=128
OLLAMA_TEMPERATURE=0.2

CHAT_MODE_DEFAULT=auto

CHAT_INSTANT_NUM_CTX=1024
CHAT_INSTANT_NUM_PREDICT=128
CHAT_INSTANT_TEMPERATURE=0.2

CHAT_THINKING_NUM_CTX=2048
CHAT_THINKING_NUM_PREDICT=384
CHAT_THINKING_TEMPERATURE=0.2


